# ================================================
# Production Environment Variables
# Perpustakaan Digital
# ================================================
# Copy this file to .env and fill in production values
# NEVER commit the actual .env file!

# ---- Application ----
NODE_ENV=production
APP_NAME=PerpustakaanDigital
APP_URL=https://perpustakaandigital.com
FRONTEND_URL=https://perpustakaandigital.com

# ---- Database (MySQL) ----
DB_HOST=mysql
DB_PORT=3306
DB_NAME=perpustakaan_digital
DB_USER=perpus_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_POOL_MIN=5
DB_POOL_MAX=20

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- JWT Secrets (generate with: openssl rand -hex 64) ----
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- SMTP (Email) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Perpustakaan Digital
SMTP_FROM_EMAIL=noreply@perpustakaandigital.com

# ---- CORS ----
CORS_ORIGINS=https://perpustakaandigital.com

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ---- Logging ----
LOG_LEVEL=info
