# =============================================
# FILE UPLOAD
# =============================================
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_DIR=uploads

# =============================================
# RATE LIMITING
# =============================================
