DEFAULT_MAX_BOOKS_PER_STUDENT=3
DEFAULT_PENALTY_RATE_PER_DAY=1000
DEFAULT_ALLOW_EXTENSIONS=true
DEFAULT_MAX_EXTENSIONS=1
RESERVATION_TIMEOUT_HOURS=48

# =============================================
# AUDIT & RETENTION
# =============================================
