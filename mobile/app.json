{
  "expo": {
    "name": "Perpustakaan Ahmad",
    "slug": "perpustakaan-digital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera diperlukan untuk scan QR code buku",
        "NSLocationWhenInUseUsageDescription": "Lokasi digunakan untuk logging scan QR"
      }
    },
    "android": {
      "package": "com.perpustakaan.digital",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1120"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan akses kamera untuk scan QR code"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Izinkan akses lokasi untuk logging scan"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF231F7C"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6ffd7622-1ea9-40f6-b35f-819256609e8f"
      }
    }
  }
}
